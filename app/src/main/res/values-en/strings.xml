    <string name="filters_title">Filters — %1$s</string>
    <string name="filters_intro">All municipalities remain on the map. Filters adjust how suitable each one is.</string>

    <string name="rent_min_title">Minimum rent</string>
    <string name="rent_min_subtitle">Lowest rent level included in the calculation.</string>

    <string name="rent_max_title">Maximum rent</string>
    <string name="rent_max_subtitle">Highest rent level included in the calculation.</string>
    <string name="rent_scale_title">Rent scale: 0 to 20</string>
    <string name="rent_scale_body">This is not a price in euros. It is an internal scale: 0 means lower rent and 20 means higher rent. The score considers municipalities inside the selected range.</string>

    <string name="filters_weights_title">Criteria importance</string>

    <string name="weight_rent_title">Rent weight</string>
    <string name="weight_rent_subtitle">The higher, the more the score favours municipalities with lower median rent.</string>
    <string name="weight_rent_info_title">How the rent weight works</string>
    <string name="weight_rent_info_body">Median rent per m² data is published quarterly by INE — the Portuguese National Statistics Institute. Only municipalities with more than 100,000 inhabitants have official values (24 out of 308); for the rest, this dimension does not contribute to the score.\n\nScoring is inverse: the municipality with the lowest available rent gets 1.0, the highest gets 0.0. Increasing the weight favours more affordable municipalities.</string>

    <string name="weight_schools_title">Schools weight</string>
    <string name="weight_schools_subtitle">The higher, the more the score values school availability.</string>
    <string name="weight_schools_info_title">How the schools weight works</string>
    <string name="weight_schools_info_body">Number of schools registered per municipality (official Ministry of Education data for the most recent school year, all 308 municipalities).\n\nThe count is smoothed with the natural logarithm before normalization so that small municipalities are not crushed by the big urban centres. The municipality with most schools gets 1.0, the one with fewest gets 0.0.</string>

    <string name="weight_hospitals_title">Hospitals weight</string>
    <string name="weight_hospitals_subtitle">The higher, the more the score values hospital availability.</string>
    <string name="weight_hospitals_info_title">How the hospitals weight works</string>
    <string name="weight_hospitals_info_body">Number of hospitals registered per municipality in 2024 (official data, all 308 municipalities).\n\nThe count is smoothed with the natural logarithm before normalization to reduce the effect of large urban areas. The municipality with most hospitals gets 1.0, the one with fewest gets 0.0.</string>

    <string name="weight_crime_title">Crime weight</string>
    <string name="weight_crime_subtitle">The higher, the more the score penalises municipalities with more crime.</string>
    <string name="weight_crime_info_title">How the crime weight works</string>
    <string name="weight_crime_info_body">Total crimes registered per municipality in 2024 (official data, all 308 municipalities).\n\nScoring is inverse: the municipality with the fewest crimes gets 1.0, the one with most gets 0.0. Increasing the weight pushes the ranking towards safer areas.</string>

